# Dependencies
node_modules/
web/node_modules/
server/node_modules/

# Build output
dist/
!plugins/*/dist/
web/dist/
server/dist/

# Vite / TypeScript cache
web/.vite/
**/.vite/
*.tsbuildinfo

# Environment & credentials (do not commit real API keys or tokens)
.env
.env.*
!.env.example
!.env*.example
*.pem
*.p12
*.key

# 用户运行时数据（含 API key、提示词、对话、lorebook、角色卡等）
/data/*
!/data/README.md
# 历史遗留路径（若存在则忽略）
server/data/

# 本地配置（DATA_DIR 等），由 config.example.json 派生
/config.json

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# OS
.DS_Store
Thumbs.db

# IDE / editor
.idea/
.vscode/*
!.vscode/extensions.json
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Tests / coverage
coverage/
.nyc_output/

# Local-only overrides
*.local

# Design iteration screenshots (设计稿 .html / .mjs 保留，截图过程产物忽略)
_design/*.png
_design/*.jpg
_design/*.jpeg

# Agent / scratch
.tmp/
