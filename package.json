{
  "name": "arousal-pub",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "typecheck": "vue-tsc -p web/tsconfig.app.json --noEmit",
    "build": "npm run build -w web"
  }
}
