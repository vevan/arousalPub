{
  "name": "arousal-pub",
  "private": true,
  "workspaces": [
    "server",
    "web"
  ],
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "yaml": "^2.8.0"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "handlebars": "^4.7.8"
  },
  "scripts": {
    "dev": "node scripts/run-dev.mjs",
    "dev:server": "npm run dev -w server",
    "dev:web": "npm run dev -w web",
    "build:plugins": "node scripts/build-plugins.mjs",
    "check:host-no-plugin-ids": "node scripts/check-host-no-plugin-ids.mjs",
    "verify:host-no-bundled": "node scripts/verify-host-build-without-bundled.mjs",
    "check:ci": "node scripts/verify-shared-sync.mjs && npm run check:host-no-plugin-ids && npm run verify:host-no-bundled && npm run build:plugins && npm run typecheck && npm test -w server",
    "migrate:curated-memory": "node --import tsx scripts/migrate-curated-memory-to-plot-summary.ts",
    "generate:bundled-registry": "node scripts/generate-bundled-registry.mjs --write",
    "typecheck": "npm run typecheck -w web",
    "build": "node scripts/build.mjs",
    "start": "node scripts/run-prod.mjs"
  }
}
