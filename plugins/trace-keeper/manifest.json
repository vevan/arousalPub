{
  "id": "trace-keeper",
  "name": "Trace Keeper",
  "version": "0.1.0",
  "hooks": [
    "resolveAfterAssemblePromptsAddition",
    "resolveTurnPluginEntriesFromAssistant",
    "formatPluginContextBlocks"
  ],
  "assembleInjection": {
    "slots": {
      "default": 500
    },
    "slotSettingsKeys": {
      "default": "injectionOrderDefault"
    }
  },
  "turnPlugins": {
    "mergeMode": "receive-scoped",
    "receiveIdKey": "receiveId"
  },
  "serverActions": [
    {
      "name": "regenerate-separate",
      "permissions": ["plugin.complete", "conversation.read"]
    },
    {
      "name": "patch-state",
      "permissions": ["turn.plugins.write", "conversation.read"]
    }
  ],
  "lifecycle": {
    "onCharacterPrimaryChanged": true
  },
  "memory": {
    "stripBlockTags": ["ex-trace-keeper"]
  },
  "permissions": [
    "conversation.read",
    "turn.read",
    "turn.plugins.write",
    "plugin.complete"
  ],
  "settingsSchema": {
    "version": 1,
    "dialogMaxWidth": 920,
    "fields": [
      {
        "key": "injectionOrderDefault",
        "type": "number",
        "labelKey": "injectionOrderDefaultLabel",
        "descriptionKey": "injectionOrderDefaultDesc",
        "min": 0,
        "max": 9999,
        "default": 500
      },
      {
        "key": "activeBundleId",
        "type": "string",
        "labelKey": "activeBundleIdLabel",
        "descriptionKey": "activeBundleIdDesc",
        "default": "scene-tracker-default",
        "widget": "bundleSelect",
        "bundleSelect": {
          "listFieldKey": "bundleList",
          "builtinValue": "scene-tracker-default",
          "builtinLabelKey": "bundleBuiltinOption"
        }
      },
      {
        "key": "apiConfigId",
        "type": "apiPreset",
        "labelKey": "apiConfigIdLabel",
        "descriptionKey": "apiConfigIdDesc",
        "default": ""
      },
      {
        "key": "separateTurnCount",
        "type": "number",
        "labelKey": "separateTurnCountLabel",
        "descriptionKey": "separateTurnCountDesc",
        "default": "4"
      },
      {
        "key": "validateSampleStateJson",
        "type": "boolean",
        "labelKey": "validateSampleStateJsonLabel",
        "descriptionKey": "validateSampleStateJsonDesc",
        "default": true
      },
      {
        "key": "bundleList",
        "type": "objectList",
        "labelKey": "bundleListLabel",
        "descriptionKey": "bundleListDesc",
        "default": "[]",
        "objectListValidation": "bundleList",
        "validateSampleStateWhen": "validateSampleStateJson",
        "reservedObjectListIds": ["scene-tracker-default"],
        "itemFields": [
          {
            "key": "label",
            "type": "string",
            "labelKey": "bundleItemLabelLabel",
            "descriptionKey": "bundleItemLabelDesc",
            "required": true
          },
          {
            "key": "systemPromptTemplate",
            "type": "text",
            "labelKey": "bundleItemSystemPromptLabel",
            "descriptionKey": "bundleItemSystemPromptDesc",
            "widget": "promptTemplate",
            "defaultKey": "systemPromptTemplateDefault",
            "maxLength": 0
          },
          {
            "key": "separateSystemPromptTemplate",
            "type": "text",
            "labelKey": "bundleItemSeparateSystemPromptLabel",
            "descriptionKey": "bundleItemSeparateSystemPromptDesc",
            "widget": "promptTemplate",
            "defaultKey": "separateSystemPromptTemplateDefault",
            "maxLength": 0
          },
          {
            "key": "sampleStateJson",
            "type": "text",
            "labelKey": "bundleItemSampleStateLabel",
            "descriptionKey": "bundleItemSampleStateDesc",
            "defaultKey": "bundleSampleStateJsonDefault",
            "widget": "jsonSampleState",
            "maxLength": 0
          },
          {
            "key": "template",
            "type": "text",
            "labelKey": "bundleItemTemplateLabel",
            "descriptionKey": "bundleItemTemplateDesc",
            "defaultKey": "bundleTemplateDefault",
            "maxLength": 0
          },
          {
            "key": "stylesheet",
            "type": "text",
            "labelKey": "bundleItemStylesheetLabel",
            "descriptionKey": "bundleItemStylesheetDesc",
            "defaultKey": "bundleStylesheetDefault",
            "maxLength": 0
          }
        ]
      }
    ]
  },
  "conversationSettingsSchema": {
    "version": 1,
    "fields": [
      {
        "key": "bundleId",
        "type": "string",
        "labelKey": "convBundleIdLabel",
        "descriptionKey": "convBundleIdDesc",
        "default": "",
        "widget": "bundleSelect",
        "bundleSelect": {
          "listFieldKey": "bundleList",
          "inheritOption": true,
          "inheritLabelKey": "convBundleInheritOption"
        }
      },
      {
        "key": "separateTurnCount",
        "type": "number",
        "labelKey": "convSeparateTurnCountLabel",
        "descriptionKey": "convSeparateTurnCountDesc",
        "default": ""
      }
    ]
  },
  "ui": {
    "eagerOnRoutes": ["chat"],
    "slots": [
      {
        "name": "turn-block-head",
        "entry": "./dist/web.mjs"
      }
    ]
  }
}
