{
  "id": "trace-keeper",
  "name": "Trace Keeper",
  "version": "0.1.0",
  "hooks": [
    "afterAssemblePrompts",
    "resolveTurnPluginEntriesFromAssistant"
  ],
  "memory": {
    "stripBlockTags": ["ex-trace-keeper"]
  },
  "permissions": [
    "conversation.read",
    "turn.read",
    "turn.plugins.write",
    "plugin.complete"
  ],
  "settingsSchema": {
    "version": 1,
    "fields": [
      {
        "key": "activeBundleId",
        "type": "string",
        "labelKey": "activeBundleIdLabel",
        "descriptionKey": "activeBundleIdDesc",
        "default": "scene-tracker-default"
      },
      {
        "key": "apiConfigId",
        "type": "apiPreset",
        "labelKey": "apiConfigIdLabel",
        "descriptionKey": "apiConfigIdDesc",
        "default": ""
      },
      {
        "key": "separateTurnCount",
        "type": "number",
        "labelKey": "separateTurnCountLabel",
        "descriptionKey": "separateTurnCountDesc",
        "default": "4"
      },
      {
        "key": "validateSampleStateJson",
        "type": "boolean",
        "labelKey": "validateSampleStateJsonLabel",
        "descriptionKey": "validateSampleStateJsonDesc",
        "default": true
      },
      {
        "key": "bundleList",
        "type": "objectList",
        "labelKey": "bundleListLabel",
        "descriptionKey": "bundleListDesc",
        "default": "[]",
        "itemFields": [
          {
            "key": "label",
            "type": "string",
            "labelKey": "bundleItemLabelLabel",
            "descriptionKey": "bundleItemLabelDesc",
            "required": true
          },
          {
            "key": "systemPromptTemplate",
            "type": "text",
            "labelKey": "bundleItemSystemPromptLabel",
            "descriptionKey": "bundleItemSystemPromptDesc",
            "widget": "promptTemplate",
            "defaultKey": "systemPromptTemplateDefault",
            "maxLength": 0
          },
          {
            "key": "separateSystemPromptTemplate",
            "type": "text",
            "labelKey": "bundleItemSeparateSystemPromptLabel",
            "descriptionKey": "bundleItemSeparateSystemPromptDesc",
            "widget": "promptTemplate",
            "defaultKey": "separateSystemPromptTemplateDefault",
            "maxLength": 0
          },
          {
            "key": "sampleStateJson",
            "type": "text",
            "labelKey": "bundleItemSampleStateLabel",
            "descriptionKey": "bundleItemSampleStateDesc",
            "defaultKey": "bundleSampleStateJsonDefault",
            "maxLength": 0
          },
          {
            "key": "template",
            "type": "text",
            "labelKey": "bundleItemTemplateLabel",
            "descriptionKey": "bundleItemTemplateDesc",
            "defaultKey": "bundleTemplateDefault",
            "maxLength": 0
          },
          {
            "key": "stylesheet",
            "type": "text",
            "labelKey": "bundleItemStylesheetLabel",
            "descriptionKey": "bundleItemStylesheetDesc",
            "defaultKey": "bundleStylesheetDefault",
            "maxLength": 0
          }
        ]
      }
    ]
  },
  "conversationSettingsSchema": {
    "version": 1,
    "fields": [
      {
        "key": "bundleId",
        "type": "string",
        "labelKey": "convBundleIdLabel",
        "descriptionKey": "convBundleIdDesc",
        "default": ""
      },
      {
        "key": "separateTurnCount",
        "type": "number",
        "labelKey": "convSeparateTurnCountLabel",
        "descriptionKey": "convSeparateTurnCountDesc",
        "default": ""
      }
    ]
  },
  "ui": {
    "slots": [
      {
        "name": "turn-block-head",
        "entry": "./dist/web.mjs"
      }
    ]
  }
}
